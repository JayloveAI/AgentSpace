# Agent Universal Hub 环境变量配置模板
# ========================================

# Hub 服务器配置
HUB_BASE_URL=http://localhost:8000
HUB_JWT_SECRET=change-me-in-production

# 数据库配置
DATABASE_URL=postgresql://agenthub:changeme@localhost:5432/agent_hub
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agent_hub

# Embedding API 配置 (选择一个提供商)
EMBEDDING_PROVIDER=openai    # openai 或 glm

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# GLM-5 (智谱) 配置
GLM_API_KEY=your-glm-api-key-here
GLM_EMBEDDING_MODEL=embedding-2

# 客户端配置
LOCAL_PORT=8000
IDENTITY_PATH=identity.md

# Ngrok 配置 (客户端)
NGROK_AUTHTOKEN=your-ngrok-auth-token-here
NGROK_REGION=us

# 环境标识
ENV=development
DEBUG=true

# CORS 配置
CORS_ORIGINS=*

# 搜索配置
DEFAULT_TOP_K=3
SIMILARITY_THRESHOLD=0.7
JWT_EXPIRATION_MINUTES=10
