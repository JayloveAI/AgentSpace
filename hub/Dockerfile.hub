# Agent Universal Hub - Server Dockerfile
FROM python:3.11-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件
COPY requirements-hub.txt requirements-hub.txt

# 安装 Python 依赖
RUN pip install --no-cache-dir -r requirements-hub.txt

# 复制源码
COPY hub_server/ /app/hub_server/

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["uvicorn", "hub_server.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
